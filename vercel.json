{
  "functions": {
    "api/chat.js": {
      "includeFiles": "assets/**"
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/about.html", "destination": "/pages/about.html" },
    { "source": "/dashboard.html", "destination": "/pages/dashboard.html" },
    { "source": "/inventory.html", "destination": "/pages/inventory.html" },
    { "source": "/ai-coding-portfolio.html", "destination": "/pages/ai-coding-portfolio.html" },
    { "source": "/member-portal-overhaul.html", "destination": "/pages/member-portal-overhaul.html" }
  ],
  "redirects": [
    {
      "source": "/design-system.html",
      "destination": "/ai-coding-portfolio.html",
      "permanent": true
    },
    {
      "source": "/portfolio-kb.json",
      "destination": "/assets/portfolio-kb.json",
      "permanent": true
    },
    {
      "source": "/llms.txt",
      "destination": "/assets/llms.txt",
      "permanent": true
    }
  ]
}
